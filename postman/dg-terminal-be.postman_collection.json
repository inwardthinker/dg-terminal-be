{
  "info": {
    "name": "dg-terminal-be",
    "description": "API tests for dg-terminal-be (NestJS).\n\n**Auth:** Portfolio routes require a non-empty `Authorization` header (value is not validated — use any Bearer token for local dev).\n\n**Wallet:** Set the `wallet` collection variable to a valid EVM address (`0x` + 40 hex chars).\n\n**Users:** Onboarding/session routes live under `/api/users` and do not require `Authorization`. Data is stored in `public.\"DG3_user\"`. Frontend sends Privy identity token in cookie (`privy-id-token`) or header (`privy-id-token`), and backend derives the user from token claims. You can still optionally pass `onboardingUsername` / `onboardingEmail` for local testing overrides on onboarding auth. Use `baseUrl` `http://localhost:3000` for local runs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test(\"Response is JSON\", function () {",
          "  pm.response.to.have.header(\"Content-Type\");",
          "  pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
          "});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://dg-terminal-be-production.up.railway.app"
    },
    {
      "key": "wallet",
      "value": "0x798a7921f5b2c684ecbaa7a6ae216a819fa6cc72"
    },
    {
      "key": "authorization",
      "value": "Bearer dev-token"
    },
    {
      "key": "onboardingUsername",
      "value": "dev_trader"
    },
    {
      "key": "onboardingEmail",
      "value": "dev.user@example.com"
    },
    {
      "key": "privyIdToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "App",
      "item": [
        {
          "name": "GET / (hello)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/",
            "description": "Root handler — returns plain text from `AppService`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "POST onboarding/auth (new user path, token in cookie)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "privy-id-token",
                "value": "{{privyIdToken}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{baseUrl}}/api/users/onboarding/auth",
            "description": "Upserts user from Privy identity token (`privy-id-token`) and sets onboarding defaults. Without email claim/match, response defaults to `existing_user=false` and `legacy_username=null`."
          },
          "response": []
        },
        {
          "name": "POST onboarding/auth (+ optional overrides)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "privy-id-token",
                "value": "{{privyIdToken}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{onboardingUsername}}\",\n  \"email\": \"{{onboardingEmail}}\"\n}"
            },
            "url": "{{baseUrl}}/api/users/onboarding/auth",
            "description": "Same as minimal auth, plus optional payload overrides for `username` and `email`. `wallet_address` always comes from the Privy token linked accounts."
          },
          "response": []
        },
        {
          "name": "PATCH onboarding/step → identity (+ username)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "privy-id-token",
                "value": "{{privyIdToken}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"step\": \"identity\",\n  \"username\": \"{{onboardingUsername}}\"\n}"
            },
            "url": "{{baseUrl}}/api/users/onboarding/step",
            "description": "Advances onboarding to Step 1 (`#step=identity`). Persists `username` when sent."
          },
          "response": []
        },
        {
          "name": "PATCH onboarding/step → calibrate",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "privy-id-token",
                "value": "{{privyIdToken}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"step\": \"calibrate\",\n  \"streams\": [\n    {\n      \"stream\": \"crypto\",\n      \"markets\": [\"btc\", \"eth\"]\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/users/onboarding/step",
            "description": "Calibration completion step. Requires `streams` (1-5): `[{ stream, markets: [] }]`. On success, backend persists `dg3_user_interests`, marks onboarding complete, sets `completed_at`, and triggers feed personalisation worker asynchronously."
          },
          "response": []
        },
        {
          "name": "PATCH onboarding/step → done",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "privy-id-token",
                "value": "{{privyIdToken}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"step\": \"done\"\n}"
            },
            "url": "{{baseUrl}}/api/users/onboarding/step",
            "description": "Completes onboarding: `onboarding_complete=true`, `last_onboarding_step=done`, `onboarding_hash` null in session payload."
          },
          "response": []
        },
        {
          "name": "GET session (restore)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "privy-id-token",
                "value": "{{privyIdToken}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/users/session",
            "description": "Returns `{ onboarding_complete, last_onboarding_step, onboarding_hash, existing_user, legacy_username, user }` for the authenticated Privy user from cookie/header token. `user` contains full `users` row when found, otherwise null."
          },
          "response": []
        },
        {
          "name": "PATCH onboarding/step — 400 (invalid step)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "privy-id-token",
                "value": "{{privyIdToken}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"step\": \"not-a-step\"\n}"
            },
            "url": "{{baseUrl}}/api/users/onboarding/step",
            "description": "Expect **400** — `step` must be one of: auth, identity, calibrate, done."
          },
          "response": []
        },
        {
          "name": "PATCH onboarding/step → calibrate — 422 (invalid streams)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "privy-id-token",
                "value": "{{privyIdToken}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"step\": \"calibrate\",\n  \"streams\": []\n}"
            },
            "url": "{{baseUrl}}/api/users/onboarding/step",
            "description": "Expect **422** — calibration requires `streams` with 1 to 5 items."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Portfolio",
      "item": [
        {
          "name": "GET positions (default sort)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/positions?walletAddress={{wallet}}",
            "description": "Open positions from Polymarket Data API. Default ordering: categories by total exposure desc, then exposure desc within category."
          },
          "response": []
        },
        {
          "name": "GET positions (sort_by + sort_dir)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/positions?walletAddress={{wallet}}&sort_by=unrealized_pnl&sort_dir=asc",
            "description": "`sort_by` optional: market_name, category, venue, side, avg_entry_price, current_price, shares, cost_basis, unrealized_pnl, unrealized_pnl_pct, exposure. `sort_dir`: asc | desc."
          },
          "response": []
        },
        {
          "name": "GET positions — 401 (no Authorization)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/positions?walletAddress={{wallet}}",
            "description": "Expect **401** when `Authorization` is missing or empty."
          },
          "response": []
        },
        {
          "name": "GET positions — 400 (invalid wallet)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/positions?walletAddress=not-an-address",
            "description": "Expect **400** — wallet must match `^0x[a-fA-F0-9]{40}$`."
          },
          "response": []
        },
        {
          "name": "GET closed-positions (default limit)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/closed-positions?walletAddress={{wallet}}",
            "description": "Closed positions. Backend defaults: limit=30, offset=0 when omitted."
          },
          "response": []
        },
        {
          "name": "GET closed-positions (limit + offset + sort)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/closed-positions?walletAddress={{wallet}}&limit=50&offset=0&sort_by=realized_pnl&sort_dir=desc",
            "description": "`limit` 1–500 (default 30). `offset` >= 0 (default 0). Optional `sort_by` / `sort_dir` on closed-position fields."
          },
          "response": []
        },
        {
          "name": "GET trades (default per_page)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/trades?walletAddress={{wallet}}",
            "description": "Polymarket activity wrapper (`/activity`). Optional params: period (1d|7d|30d|all), page, per_page (default 25), sort_by, sort_dir, outcome."
          },
          "response": []
        },
        {
          "name": "GET trades (timestamp filters - Polymarket style)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/trades?walletAddress={{wallet}}&limit=30&offset=0&excludeDepositsWithdrawals=false&start=1776191400&end=1776882600&sortBy=TIMESTAMP&sortDirection=DESC",
            "description": "Matches Polymarket /activity timestamp filtering parameters."
          },
          "response": []
        },
        {
          "name": "GET trades — 400 (invalid period)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/trades?walletAddress={{wallet}}&period=invalid",
            "description": "Expect 400 when period is not one of: 1d, 7d, 30d, all."
          },
          "response": []
        },
        {
          "name": "GET trades — 401 (no Authorization)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/trades?walletAddress={{wallet}}",
            "description": "Expect 401 when Authorization is missing or empty."
          },
          "response": []
        },
        {
          "name": "GET summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/summary?walletAddress={{wallet}}",
            "description": "Portfolio summary sourced from `portfolio_summary`: balance, exposure, unrealized/realized PnL, rewards, derived ratios, and per-field freshness timestamps."
          },
          "response": []
        },
        {
          "name": "GET summary — 400 (invalid walletAddress)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/summary?walletAddress=not-an-address",
            "description": "Expect **400** — `walletAddress` must match `^0x[a-fA-F0-9]{40}$`."
          },
          "response": []
        },
        {
          "name": "GET summary — 401 (no Authorization)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/summary?walletAddress={{wallet}}",
            "description": "Expect **401** when `Authorization` is missing or empty."
          },
          "response": []
        }
      ]
    }
  ]
}
