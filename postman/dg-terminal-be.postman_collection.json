{
  "info": {
    "name": "dg-terminal-be",
    "description": "Staging API tests for dg-terminal-be (NestJS).\n\n**Auth:** Portfolio routes require a non-empty `Authorization` header (value is not validated — use any Bearer token for local dev).\n\n**Wallet:** Set the `wallet` collection variable to a valid EVM address (`0x` + 40 hex chars).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test(\"Response is JSON\", function () {",
          "  pm.response.to.have.header(\"Content-Type\");",
          "  pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
          "});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://dg-terminal-be-staging.up.railway.app"
    },
    {
      "key": "wallet",
      "value": "0x798a7921f5b2c684ecbaa7a6ae216a819fa6cc72"
    },
    {
      "key": "authorization",
      "value": "Bearer dev-token"
    }
  ],
  "item": [
    {
      "name": "App",
      "item": [
        {
          "name": "GET / (hello)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/",
            "description": "Root handler — returns plain text from `AppService`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Portfolio",
      "item": [
        {
          "name": "GET positions (default sort)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/positions?wallet={{wallet}}",
            "description": "Open positions from Polymarket Data API. Default ordering: categories by total exposure desc, then exposure desc within category."
          },
          "response": []
        },
        {
          "name": "GET positions (sort_by + sort_dir)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/positions?wallet={{wallet}}&sort_by=unrealized_pnl&sort_dir=asc",
            "description": "`sort_by` optional: market_name, category, venue, side, avg_entry_price, current_price, shares, cost_basis, unrealized_pnl, unrealized_pnl_pct, exposure. `sort_dir`: asc | desc."
          },
          "response": []
        },
        {
          "name": "GET positions — 401 (no Authorization)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/positions?wallet={{wallet}}",
            "description": "Expect **401** when `Authorization` is missing or empty."
          },
          "response": []
        },
        {
          "name": "GET positions — 400 (invalid wallet)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/positions?wallet=not-an-address",
            "description": "Expect **400** — wallet must match `^0x[a-fA-F0-9]{40}$`."
          },
          "response": []
        },
        {
          "name": "GET closed-positions (default limit)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/closed-positions?wallet={{wallet}}",
            "description": "Closed positions. Backend defaults: limit=30, offset=0 when omitted."
          },
          "response": []
        },
        {
          "name": "GET closed-positions (limit + offset + sort)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/closed-positions?wallet={{wallet}}&limit=50&offset=0&sort_by=realized_pnl&sort_dir=desc",
            "description": "`limit` 1–500 (default 30). `offset` >= 0 (default 0). Optional `sort_by` / `sort_dir` on closed-position fields."
          },
          "response": []
        },
        {
          "name": "GET trades (default per_page)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/trades?wallet={{wallet}}",
            "description": "Polymarket activity wrapper (`/activity`). Optional params: period (1d|7d|30d|all), page, per_page (default 25), sort_by, sort_dir, outcome."
          },
          "response": []
        },
        {
          "name": "GET trades (timestamp filters - Polymarket style)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/trades?wallet={{wallet}}&limit=30&offset=0&excludeDepositsWithdrawals=false&start=1776191400&end=1776882600&sortBy=TIMESTAMP&sortDirection=DESC",
            "description": "Matches Polymarket /activity timestamp filtering parameters."
          },
          "response": []
        },
        {
          "name": "GET trades — 400 (invalid period)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/trades?wallet={{wallet}}&period=invalid",
            "description": "Expect 400 when period is not one of: 1d, 7d, 30d, all."
          },
          "response": []
        },
        {
          "name": "GET trades — 401 (no Authorization)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/trades?wallet={{wallet}}",
            "description": "Expect 401 when Authorization is missing or empty."
          },
          "response": []
        },
        {
          "name": "GET summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/summary?walletAddress={{wallet}}",
            "description": "Portfolio summary sourced from `portfolio_summary`: balance, exposure, unrealized/realized PnL, rewards, derived ratios, and per-field freshness timestamps."
          },
          "response": []
        },
        {
          "name": "GET summary — 400 (invalid walletAddress)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authorization}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/summary?walletAddress=not-an-address",
            "description": "Expect **400** — `walletAddress` must match `^0x[a-fA-F0-9]{40}$`."
          },
          "response": []
        },
        {
          "name": "GET summary — 401 (no Authorization)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/portfolio/summary?walletAddress={{wallet}}",
            "description": "Expect **401** when `Authorization` is missing or empty."
          },
          "response": []
        }
      ]
    }
  ]
}
